# ── Public (exposed to browser bundle via VITE_ prefix) ──────────────────────

# Clerk publishable key — find it in your Clerk dashboard under "API Keys"
VITE_CLERK_PUBLISHABLE_KEY=

# URL of the backend GraphQL endpoint
VITE_GRAPHQL_URL=http://localhost:5063/graphql

# ── Server-only (never sent to the browser) ───────────────────────────────────

# Clerk secret key — find it in your Clerk dashboard under "API Keys"
# Keep this private; never prefix with VITE_
CLERK_SECRET_KEY=

# GitHub Personal Access Token used to create feedback issues
# Required scope: repo (or issues on the target repo)
# Generate at: https://github.com/settings/tokens
GITHUB_FEEDBACK_TOKEN=

# Target GitHub repo for feedback issues (format: owner/repo)
GITHUB_FEEDBACK_REPO=HaakonSvane/troji
