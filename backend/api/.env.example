# Backend environment variables — loaded automatically by `just run-backend`
# Copy this file to .env and fill in your values. Never commit .env.

# ── Database connection ───────────────────────────────────────────────────────
# These are combined with Host/Port from appsettings.json (defaults: localhost:5432)
# and also used by docker-compose to provision the Postgres container.

Database__User=
Database__Password=

# ── Auth (overrides appsettings.Development.json in non-dev environments) ─────
# Clerk authority URL — find it in your Clerk dashboard under "API Keys" > "Advanced"
# Format: https://<your-clerk-instance>.clerk.accounts.dev  (dev)
#         https://<your-clerk-instance>.clerk.accounts.com  (prod)
# Auth__Authority=

# ── CORS (optional — defaults to http://localhost:5173) ───────────────────────
# Comma-separated list of allowed frontend origins
# Cors__Origins=https://your-production-domain.com
